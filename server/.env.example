# PetFriends Server Configuration
# Copy this file to .env and fill in the values

# Server port
PORT=3000

# JWT Secret for token signing (change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Telegram Bot Token (get from @BotFather)
# Used to verify WebApp init data
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional: MongoDB connection string (if using MongoDB instead of in-memory DB)
# MONGODB_URI=mongodb://localhost:27017/petfriends
